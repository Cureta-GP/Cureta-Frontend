## 6. ViewModel — `AuthViewModel`

> **Responsibility:** Holds UI state (loading, success, error). Calls `AuthRepository`. Exposes results to the View via `ChangeNotifier`.

### File: `lib/features/authentcation/veiw_model/auth_view_model.dart`

```dart
import 'package:flutter/material.dart';
import 'package:cureta/core/error_handling/app_exceptions.dart';
import 'package:cureta/core/Services/GetItServices.dart';
import '../data/repo/auth_repository.dart';
import '../data/models/user_model.dart';

class AuthViewModel extends ChangeNotifier {
  final AuthRepository _authRepository = getIt.get<AuthRepository>();

  // ──── State ────
  bool _isLoading = false;
  bool get isLoading => _isLoading;

  UserModel? _user;
  UserModel? get user => _user;

  AppException? _error;
  AppException? get error => _error;

  bool _isSuccess = false;
  bool get isSuccess => _isSuccess;

  // ──── Private helpers ────
  void _setLoading(bool value) {
    _isLoading = value;
    notifyListeners();
  }

  void _setError(AppException? exception) {
    _error = exception;
    notifyListeners();
  }

  void clearError() {
    _error = null;
    notifyListeners();
  }

  void _reset() {
    _error = null;
    _isSuccess = false;
  }

  // ──────────────────────────────────────
  //  LOGIN
  // ──────────────────────────────────────
  Future<void> login({
    required String email,
    required String password,
  }) async {
    _reset();
    _setLoading(true);

    try {
      _user = await _authRepository.login(
        email: email,
        password: password,
      );
      _isSuccess = true;
    } on AppException catch (e) {
      _setError(e);
    } catch (e) {
      _setError(AppException.server());
    } finally {
      _setLoading(false);
    }
  }

  // ──────────────────────────────────────
  //  SIGN-UP
  // ──────────────────────────────────────
  Future<void> signUp({
    required String username,
    required String email,
    required String phone,
    required String password,
  }) async {
    _reset();
    _setLoading(true);

    try {
      _user = await _authRepository.signUp(
        username: username,
        email: email,
        phone: phone,
        password: password,
      );
      _isSuccess = true;
    } on AppException catch (e) {
      _setError(e);
    } catch (e) {
      _setError(AppException.server());
    } finally {
      _setLoading(false);
    }
  }

  // ──────────────────────────────────────
  //  LOGOUT
  // ──────────────────────────────────────
  Future<void> logout() async {
    await _authRepository.logout();
    _user = null;
    _isSuccess = false;
    notifyListeners();
  }
}
```

